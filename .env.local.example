# Copy this file to .env.local for local development, or set these as
# Environment Variables in your Vercel project settings for production.
# See EMAIL-SETUP.md for the full walkthrough.

# Required — from https://resend.com/api-keys
RESEND_API_KEY=

# Optional — inbox that receives enquiries. Defaults to the email in
# src/lib/site.ts if unset.
ENQUIRY_TO_EMAIL=

# Optional — sender address shown on enquiry emails. Defaults to Resend's
# shared test sender, which works immediately with no domain setup.
# Once a domain is verified in Resend, switch this to an address on your
# own domain, e.g. enquiries@expertsafety.in
ENQUIRY_FROM_EMAIL=

# TinaCMS — both optional. Local editing (`npm run tina-dev`) works with
# neither of these set. Only add them to switch the /admin editor over to
# Tina Cloud's hosted, git-backed mode (create a project at app.tina.io):
NEXT_PUBLIC_TINA_CLIENT_ID=
TINA_TOKEN=
